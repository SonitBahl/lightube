#!/bin/bash

CONFIG="$HOME/.config/lightube.conf"

[ -f "$CONFIG" ] && source "$CONFIG"

source "$(dirname "$0")/lib/search.sh"
source "$(dirname "$0")/lib/menu.sh"

echo "Lightube - Terminal YouTube Player"

read -p "Search YouTube: " query

echo ""
echo "Fetching videos..."
echo ""

mapfile -t results < <(search "$query")

if [ ${#results[@]} -eq 0 ]; then
    echo "No results found."
    exit
fi

selected=$(printf "%s\n" "${results[@]}" | show_menu)

[ -z "$selected" ] && exit

IFS=$'\t' read -r title url channel views likes comments duration <<< "$selected"

echo ""
echo "Selected:"
echo "$title"
echo "$url"